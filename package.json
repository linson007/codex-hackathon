{
  "name": "contextos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "contextos": "./bin/contextos.js"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && npm run build -w @contextos/ui",
    "cli:ref": "node scripts/generate-cli-ref.mjs",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "demo": "node scripts/demo.mjs",
    "dev:ui": "npm run dev -w @contextos/ui",
    "dev:api": "npm run dev -w @contextos/api",
    "contextos": "tsx apps/cli/src/index.ts"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.2.0",
    "@xyflow/react": "12.10.2",
    "better-sqlite3": "11.10.0",
    "commander": "12.1.0",
    "cors": "2.8.6",
    "express": "4.22.1",
    "mermaid": "11.14.0",
    "openai": "4.104.0",
    "ora": "9.4.0",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "22.19.17",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "10.2.1",
    "prettier": "3.8.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.0",
    "vitest": "2.1.9"
  }
}
